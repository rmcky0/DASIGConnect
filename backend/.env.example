# DASIGConnect Backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── Database (Supabase Session Pooler) ───────────────────────────────────────
# Keep credentials out of the JDBC URL. Set user/password on the next lines.
DATABASE_URL=jdbc:postgresql://<host>:5432/postgres
DATABASE_USER=postgres.<project-ref>
DATABASE_PASSWORD=<your-supabase-db-password>

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=<min-32-char-random-secret>
JWT_EXPIRATION_MS=28800000

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Option A: Office 365 SMTP AUTH (use if your school allows it)
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=your-address@institution.edu.ph
MAIL_PASSWORD=<your-email-password>
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_FROM=noreply@institution.edu.ph

# Option B: Transactional provider (Resend, Mailgun, SendGrid)
# Replace values above with provider SMTP credentials

# ── Frontend URL (used in invitation/reset email links) ───────────────────────
APP_FRONTEND_BASE_URL=http://localhost:5173

# ── External APIs ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# ── Facebook Graph API ────────────────────────────────────────────────────────
FACEBOOK_PAGE_ACCESS_TOKEN=<long-lived-page-access-token>
FACEBOOK_PAGE_ID=<numeric-page-id>

# ── Supabase Storage ──────────────────────────────────────────────────────────
DASIG_SUPABASE_URL=https://<project-ref>.supabase.co
DASIG_SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
DASIG_SUPABASE_STORAGE_BUCKET=dasigconnect-media
